# =============================================================================
# Suno Song Studio - example environment
# =============================================================================
# Copy this file to ".env" and replace the CHANGE_ME values.
# Every variable below is read by app/config.py. Comments explain what it does
# in the backend and what the user will notice in the React frontend/admin UI.


# -----------------------------------------------------------------------------
# App identity and runtime mode
# -----------------------------------------------------------------------------

# Backend: Display name used in metadata, logs and some provider requests.
# Frontend/Admin: Used as application name where the runtime config is shown.
APP_NAME=Suno FastAPI App

# Backend: Runtime profile label. Use "local" for development and "production" on servers.
# Frontend/Admin: Helps distinguish local/server instances in diagnostics and status views.
APP_ENV=production

# Backend: Enables verbose error/debug behavior when true.
# Frontend/Admin: Can expose more diagnostic details; keep false for public/production use.
DEBUG=false


# -----------------------------------------------------------------------------
# SunoAPI.org provider
# -----------------------------------------------------------------------------

# Backend: API token for SunoAPI.org generation, extend, upload/cover/add-vocals and task imports.
# Frontend/Admin: Music workflows are unavailable or fail until this key is configured.
SUNO_API_KEY=CHANGE_ME

# Backend: Base URL for SunoAPI.org REST calls.
# Frontend/Admin: Affects all Suno generation/import actions triggered from /music and /status.
SUNO_BASE_URL=https://api.sunoapi.org

# Backend: Base URL used for SunoAPI file-upload related operations.
# Frontend/Admin: Affects upload-based workflows such as extend/upload/cover/add vocals.
SUNO_FILE_UPLOAD_BASE_URL=https://sunoapiorg.redpandaai.co

# Backend: Enables read-only import of public Suno clip IDs through Suno's clip API.
# Frontend/Admin: Controls whether public Suno song imports can enrich local library metadata.
SUNO_CLIP_IMPORT_ENABLED=true

# Backend: URL template for public Suno clip lookup. "{id}" is replaced with the clip/song ID.
# Frontend/Admin: Used by status/library import repair flows when importing public Suno content.
SUNO_CLIP_API_URL=https://studio-api.prod.suno.com/api/clip/{id}

# Backend: User-Agent sent to Suno's public clip API.
# Frontend/Admin: Helps clip imports work reliably; not displayed directly.
SUNO_CLIP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/149.0.0.0 Safari/537.36

# Backend: Timeout for a single public Suno clip lookup.
# Frontend/Admin: Prevents import/status actions from hanging too long on unreachable clips.
SUNO_CLIP_REQUEST_TIMEOUT_SECONDS=30

# Backend: Timeout per SunoAPI.org task ID during batch import.
# Frontend/Admin: The /status task import reports failed/skipped IDs instead of hanging forever.
SUNO_TASK_IMPORT_ITEM_TIMEOUT_SECONDS=150

# Backend: Optional JSON with prompt/style/title length limits per Suno model.
# Frontend/Admin: /music uses these limits to validate fields and avoid provider rejections.
SUNO_MODEL_LIMITS_JSON={"V5_5":{"simple_prompt":500,"custom_prompt":5000,"style":1000,"title":100},"V5":{"simple_prompt":500,"custom_prompt":5000,"style":1000,"title":100},"V4_5ALL":{"simple_prompt":500,"custom_prompt":5000,"style":1000,"title":100},"V4_5":{"simple_prompt":500,"custom_prompt":5000,"style":1000,"title":100},"V4_5PLUS":{"simple_prompt":500,"custom_prompt":5000,"style":1000,"title":100},"V4":{"simple_prompt":500,"custom_prompt":5000,"style":1000,"title":100}}

# Backend: Maximum length for generated lyrics prompts sent to Suno lyrics generation.
# Frontend/Admin: Controls validation/limits in lyrics/music generation forms.
SUNO_LYRICS_PROMPT_MAX_LENGTH=200


# -----------------------------------------------------------------------------
# Database, public URLs and callbacks
# -----------------------------------------------------------------------------

# Backend: SQLAlchemy database URL. Default uses local SQLite in the project root.
# Frontend/Admin: All library, users, tasks, settings and status data come from this database.
DATABASE_URL=sqlite:///./sunoapi_app.db

# Backend: Public origin used to build callback URLs and absolute media links.
# Frontend/Admin: Must match the reachable backend URL so provider callbacks and media links work.
PUBLIC_BASE_URL=https://sunoapi.example.tld

# Backend: Path appended to PUBLIC_BASE_URL for SunoAPI callback/webhook events.
# Frontend/Admin: Generation tasks update automatically only if callbacks reach this endpoint.
DEFAULT_CALLBACK_PATH=/api/webhooks/suno


# -----------------------------------------------------------------------------
# Generic request and polling behavior
# -----------------------------------------------------------------------------

# Backend: Default timeout for external provider HTTP requests.
# Frontend/Admin: Long actions fail with a status error instead of blocking indefinitely.
REQUEST_TIMEOUT_SECONDS=60

# Backend: Polling interval for provider task checks.
# Frontend/Admin: Controls how quickly /status and task badges refresh pending Suno tasks.
POLLING_INTERVAL_SECONDS=10

# Backend: Maximum polling attempts before giving up on a provider task.
# Frontend/Admin: Affects when pending tasks become failed/timeout in /status.
POLLING_MAX_ATTEMPTS=60

# Backend: Default page size for archive/library-style API results.
# Frontend/Admin: Influences how many items are loaded in archive/list views.
ARCHIVE_PAGE_SIZE=50


# -----------------------------------------------------------------------------
# Local audio storage and offline playback
# -----------------------------------------------------------------------------

# Backend: Audio caching mode. Use off, on_success or on_first_success.
# Frontend/Admin: "Audio lokal" badges and offline playback depend on successful local caching.
SUNO_AUDIO_CACHE_MODE=on_success

# Backend: Directory where cached audio files are stored.
# Frontend/Admin: Library/audio player uses this path through the public media route.
SUNO_AUDIO_STORAGE_DIR=storage/audio

# Backend: Public route that serves files from SUNO_AUDIO_STORAGE_DIR.
# Frontend/Admin: Audio players use this URL route for local playback.
SUNO_AUDIO_PUBLIC_ROUTE=/media/audio

# Backend: Download timeout for caching remote audio files.
# Frontend/Admin: "Inhalte pruefen" and post-generation caching fail faster on broken URLs.
SUNO_AUDIO_DOWNLOAD_TIMEOUT_SECONDS=120

# Backend: Maximum allowed audio download size in MB.
# Frontend/Admin: Prevents huge files from being cached; oversized items show as not cacheable.
SUNO_AUDIO_MAX_DOWNLOAD_MB=100

# Backend: Allowed file extensions for audio caching/materialization.
# Frontend/Admin: Unsupported files are skipped in library import/cache repair actions.
SUNO_AUDIO_ALLOWED_EXTENSIONS=.mp3,.wav,.m4a,.aac,.ogg,.flac

# Backend: Allowed content-types for audio caching/materialization.
# Frontend/Admin: Controls whether "Inhalte pruefen" accepts a remote file as audio.
SUNO_AUDIO_ALLOWED_CONTENT_TYPES=audio/mpeg,audio/mp3,audio/x-mp3,audio/wav,audio/wave,audio/x-wav,audio/mp4,audio/m4a,audio/aac,audio/ogg,audio/flac,audio/x-flac,application/octet-stream

# Backend: If true, only music/audio-like Suno results are auto-downloaded.
# Frontend/Admin: Keeps non-audio provider artifacts out of the audio library.
SUNO_AUTO_DOWNLOAD_ONLY_MUSIC=true

# Backend: Retry count for local audio downloads.
# Frontend/Admin: Improves reliability of "Inhalte pruefen" and post-generation local storage.
SUNO_AUDIO_DOWNLOAD_RETRIES=2

# Backend: Master switch for storing locally generated/imported content in portable local paths.
# Frontend/Admin: If false, library becomes more remote-link dependent; keep true for offline use.
LOCAL_CONTENT_STORAGE_ENABLED=true


# -----------------------------------------------------------------------------
# Optional OpenCLI provider
# -----------------------------------------------------------------------------

# Backend: Enables OpenCLI/browser-bridge generation as an optional provider.
# Frontend/Admin: Shows OpenCLI capability/configuration in runtime/admin areas when enabled.
SUNO_OPENCLI_ENABLED=false

# Backend: Command name or path for the OpenCLI executable.
# Frontend/Admin: Runtime config can show whether this binary is installed.
SUNO_OPENCLI_BINARY=opencli

# Backend: Maximum runtime for a complete OpenCLI operation.
# Frontend/Admin: Long OpenCLI tasks fail visibly in /status after this timeout.
SUNO_OPENCLI_TIMEOUT_SECONDS=900

# Backend: Wait timeout for OpenCLI task completion.
# Frontend/Admin: Controls how long the UI task waits for generated clips to become importable.
SUNO_OPENCLI_WAIT_TIMEOUT_SECONDS=360

# Backend: Comma-separated output formats requested from OpenCLI.
# Frontend/Admin: Determines which generated files can appear in the library after OpenCLI import.
SUNO_OPENCLI_FORMATS=mp3,metadata,cover

# Backend: If true, OpenCLI may confirm paid operations.
# Frontend/Admin: Keep false unless the admin intentionally allows paid OpenCLI actions.
SUNO_OPENCLI_CONFIRM_PAID=false

# Backend: Maximum number of OpenCLI clips imported from one operation.
# Frontend/Admin: Limits how many variants appear in library/status after OpenCLI generation.
SUNO_OPENCLI_MAX_IMPORTED_CLIPS=2

# Backend: Maps Suno-style frontend model names to OpenCLI model names.
# Frontend/Admin: Lets /music keep familiar model choices while OpenCLI receives its own IDs.
SUNO_OPENCLI_MODEL_MAP_JSON={"V5_5":"chirp-fenix","V5":"chirp-fenix","V4_5ALL":"chirp-bluejay","V4_5PLUS":"chirp-bluejay","V4_5":"chirp-bluejay","V4":"chirp-v4"}


# -----------------------------------------------------------------------------
# Local cover storage and cover repair
# -----------------------------------------------------------------------------

# Backend: Enables local caching of cover images.
# Frontend/Admin: Library/details show local cover status and keep covers after remote URLs expire.
SUNO_COVER_CACHE_ENABLED=true

# Backend: Directory where cached cover images are stored.
# Frontend/Admin: Cover thumbnails and viewer use files stored here through the public route.
SUNO_COVER_STORAGE_DIR=storage/covers

# Backend: Public route that serves local cover files.
# Frontend/Admin: Library grids, song details and cover viewer load local covers through this URL.
SUNO_COVER_PUBLIC_ROUTE=/media/covers

# Backend: Timeout for downloading cover files.
# Frontend/Admin: Cover repair/cache actions fail cleanly instead of freezing.
SUNO_COVER_DOWNLOAD_TIMEOUT_SECONDS=60

# Backend: Maximum allowed cover download size in MB.
# Frontend/Admin: Prevents oversized images from being cached or shown as local covers.
SUNO_COVER_MAX_DOWNLOAD_MB=20

# Backend: Allowed cover file extensions.
# Frontend/Admin: Upload/import/cache repair rejects unsupported image formats.
SUNO_COVER_ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.webp,.gif,.avif

# Backend: Allowed cover content-types.
# Frontend/Admin: "Inhalte pruefen" and cover upload/import use this to validate images.
SUNO_COVER_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/gif,image/avif,application/octet-stream

# Backend: Optional comma-separated mirror base URLs for missing /media files.
# Frontend/Admin: "Inhalte pruefen" can restore missing covers/audio from another instance.
LIBRARY_CONTENT_REMOTE_MEDIA_BASE_URLS=


# -----------------------------------------------------------------------------
# Transcription, SRT and subtitle generation
# -----------------------------------------------------------------------------

# Backend: Directory for SRT/transcript files and transcript metadata exports.
# Frontend/Admin: SRT buttons, detail pages and player subtitles read saved files from here.
TRANSCRIPT_STORAGE_DIR=storage/transcripts

# Backend: Default backend for SRT generation: groq, whisperx, openai_whisper_api or voxtral.
# Frontend/Admin: Preselects the SRT/transcription backend in detail/bulk actions.
TRANSCRIPT_BACKEND_DEFAULT=groq

# Backend: Default transcription language, e.g. de, en or auto.
# Frontend/Admin: Used when the frontend does not explicitly choose a language.
TRANSCRIPT_LANGUAGE_DEFAULT=de

# Backend: Model name for OpenAI Whisper API transcription.
# Frontend/Admin: Used when backend "openai_whisper_api" is selected for SRT.
TRANSCRIPT_OPENAI_MODEL=whisper-1

# Backend: Model name for Voxtral/Mistral transcription.
# Frontend/Admin: Used when backend "voxtral" is selected for SRT.
TRANSCRIPT_VOXTRAL_MODEL=voxtral-mini-latest

# Backend: Model name for Groq transcription.
# Frontend/Admin: Used when backend "groq" is selected for SRT.
TRANSCRIPT_GROQ_MODEL=whisper-large-v3

# Backend: Local WhisperX model size/name.
# Frontend/Admin: Used when admin/user selects local WhisperX SRT.
TRANSCRIPT_WHISPERX_MODEL=small

# Backend: Optional WhisperX alignment language override. Empty means auto/from request.
# Frontend/Admin: Affects word alignment quality for local WhisperX subtitles.
TRANSCRIPT_WHISPERX_ALIGN_LANGUAGE=

# Backend: WhisperX compute device: auto, cpu, cuda or mps depending on installation.
# Frontend/Admin: Determines speed/availability of local WhisperX SRT.
TRANSCRIPT_WHISPERX_DEVICE=auto

# Backend: WhisperX compute type, e.g. float16, int8 or float32.
# Frontend/Admin: Affects speed/memory use and whether local SRT succeeds on CPU/GPU.
TRANSCRIPT_WHISPERX_COMPUTE_TYPE=float16

# Backend: WhisperX batch size.
# Frontend/Admin: Higher values can be faster on GPU but may fail with low memory.
TRANSCRIPT_WHISPERX_BATCH_SIZE=16

# Backend: CPU thread override for WhisperX/torch. 0 lets the app decide.
# Frontend/Admin: Helps keep the UI responsive during local transcription on CPU.
TRANSCRIPT_WHISPERX_CPU_THREADS=0

# Backend: Allows automatic CPU-safe downgrade when WhisperX settings are not supported.
# Frontend/Admin: Reduces failed local SRT jobs on machines without CUDA.
TRANSCRIPT_WHISPERX_AUTO_CPU_DOWNGRADE=true

# Backend: Overall timeout for SRT provider requests.
# Frontend/Admin: Failed SRT jobs become visible in status instead of staying pending.
TRANSCRIPT_REQUEST_TIMEOUT_SECONDS=600

# Backend: Timeout for one Groq audio upload/transcription request.
# Frontend/Admin: Groq SRT reports retry/failure progress instead of blocking the whole page.
TRANSCRIPT_GROQ_REQUEST_TIMEOUT_SECONDS=90

# Backend: Number of retries after Groq transcription read timeouts.
# Frontend/Admin: /status step logs show retry attempts before final failure.
TRANSCRIPT_GROQ_MAX_RETRIES=2

# Backend: Creates a small temporary mono audio copy for Groq transcription.
# Frontend/Admin: Makes Groq SRT more reliable while keeping original audio unchanged.
TRANSCRIPT_GROQ_PREPROCESS_AUDIO=true

# Backend: Sample rate for Groq's temporary transcription copy.
# Frontend/Admin: Lower values reduce upload size and timeout risk for Groq SRT.
TRANSCRIPT_GROQ_PREPROCESS_SAMPLE_RATE=16000

# Backend: Bitrate for Groq's temporary transcription copy.
# Frontend/Admin: Lower values reduce upload size and timeout risk for Groq SRT.
TRANSCRIPT_GROQ_PREPROCESS_BITRATE=64k

# Backend: Safety timeout for the local SRT task wrapper.
# Frontend/Admin: Status page marks stuck SRT jobs as failed after this time.
SRT_TRANSCRIPTION_TIMEOUT_SECONDS=240

# Backend: Maximum runtime for local WhisperX SRT jobs.
# Frontend/Admin: Long local SRT tasks eventually fail visibly instead of hanging.
TRANSCRIPT_WHISPERX_TIMEOUT_SECONDS=1800

# Backend: API key for Voxtral transcription.
# Frontend/Admin: Admin/runtime config shows Voxtral as configured when set.
VOXTRAL_API_KEY=CHANGE_ME_OR_LEAVE_EMPTY

# Backend: Alternative Mistral API key used by Voxtral/Mistral flows.
# Frontend/Admin: Can make Voxtral transcription available if VOXTRAL_API_KEY is empty.
MISTRAL_API_KEY=CHANGE_ME_OR_LEAVE_EMPTY

# Backend: API key for Groq transcription and Groq chat models.
# Frontend/Admin: Enables Groq SRT and Groq AI provider options in admin/runtime config.
GROQ_API_KEY=CHANGE_ME_OR_LEAVE_EMPTY

# Backend: OpenAI-compatible Groq chat base URL. Must include /openai/v1.
# Frontend/Admin: Affects Groq as AI text provider, not Suno generation.
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Backend: Base URL for Voxtral/Mistral transcription API.
# Frontend/Admin: Affects Voxtral SRT backend availability and task execution.
VOXTRAL_BASE_URL=https://api.mistral.ai/v1


# -----------------------------------------------------------------------------
# Replicate cover generation
# -----------------------------------------------------------------------------

# Backend: API token for Replicate image generation.
# Frontend/Admin: Enables "Cover generieren" actions in library/song details.
REPLICATE_API_TOKEN=CHANGE_ME_OR_LEAVE_EMPTY

# Backend: Text model used to prepare/enrich Replicate cover prompts.
# Frontend/Admin: Affects the quality/content of AI cover prompts generated from song context.
REPLICATE_COVER_TEXT_MODEL=ibm-granite/granite-3.3-8b-instruct


# -----------------------------------------------------------------------------
# Local audio AI analysis
# -----------------------------------------------------------------------------

# Backend: Master switch for local audio analysis reports.
# Frontend/Admin: Enables audio analysis buttons/reports in song details/admin.
AUDIO_AI_ANALYSIS_ENABLED=true

# Backend: Directory for audio analysis JSON/HTML/PDF exports.
# Frontend/Admin: Export/download actions read generated reports from this storage.
AUDIO_AI_ANALYSIS_STORAGE_DIR=storage/analysis

# Backend: Maximum seconds of audio loaded for standard analysis.
# Frontend/Admin: Higher values can improve reports but make analysis slower.
AUDIO_AI_ANALYSIS_MAX_SECONDS=240

# Backend: Enables AI-written summary on top of local signal/metadata analysis.
# Frontend/Admin: Report modal shows a clearer AI overview when an AI provider is configured.
AUDIO_AI_ANALYSIS_AI_SUMMARY_ENABLED=true

# Backend: Enables optional model-based classification steps.
# Frontend/Admin: Adds richer report sections when local model dependencies are available.
AUDIO_AI_MODEL_ANALYSIS_ENABLED=true

# Backend: Cache directory for downloaded local ML/audio models.
# Frontend/Admin: First analysis can take longer; later analyses reuse cached models.
AUDIO_AI_MODEL_CACHE_DIR=storage/models/huggingface

# Backend: Seconds of audio used for heavier model analysis.
# Frontend/Admin: Balances detail vs. runtime in the audio analysis report.
AUDIO_AI_MODEL_ANALYSIS_SECONDS=30

# Backend: Number of top model labels/results stored in the report.
# Frontend/Admin: Controls how many genre/mood/classification hints are displayed.
AUDIO_AI_MODEL_ANALYSIS_TOP_K=8

# Backend: AcoustID key for Chromaprint lookup/copyright-known-recording checks.
# Frontend/Admin: Adds known-recording/copyright hints to audio analysis reports when set.
ACOUSTID_API_KEY=CHANGE_ME_OR_LEAVE_EMPTY


# -----------------------------------------------------------------------------
# Startup recovery, local task watchdog and background execution
# -----------------------------------------------------------------------------

# Backend: Recovers unfinished Suno tasks after FastAPI restart.
# Frontend/Admin: Pending tasks can continue/update in /status after a server restart.
SUNO_STARTUP_RECOVERY_ENABLED=true

# Backend: Delay before startup recovery begins.
# Frontend/Admin: Avoids status noise immediately after boot.
SUNO_STARTUP_RECOVERY_INITIAL_DELAY_SECONDS=15

# Backend: Interval between startup recovery polling attempts.
# Frontend/Admin: Controls how quickly recovered tasks update in /status.
SUNO_STARTUP_RECOVERY_INTERVAL_SECONDS=30

# Backend: Number of recovery attempts for each startup cycle.
# Frontend/Admin: Determines how long restarted tasks are checked before giving up.
SUNO_STARTUP_RECOVERY_ATTEMPTS=10

# Backend: Maximum number of pending tasks recovered per startup cycle.
# Frontend/Admin: Prevents a large backlog from flooding /status after restart.
SUNO_STARTUP_RECOVERY_LIMIT=30

# Backend: Enables watchdog for stale local/app tasks.
# Frontend/Admin: Stuck tasks become failed/finished instead of staying active forever.
TASK_WATCHDOG_ENABLED=true

# Backend: Minutes before a task without heartbeat is considered stale.
# Frontend/Admin: Controls when /status stops showing stale jobs as running.
TASK_WATCHDOG_STALE_MINUTES=30

# Backend: Watchdog check interval.
# Frontend/Admin: Affects how quickly stale task badges/status rows are repaired.
TASK_WATCHDOG_INTERVAL_SECONDS=120

# Backend: Local background execution mode: thread, spawn, fork or auto.
# Frontend/Admin: Impacts reliability/performance of heavy local jobs such as SRT/stems.
BACKGROUND_WORKER_START_METHOD=thread

# Backend: Stale threshold for local app tasks without heartbeat.
# Frontend/Admin: Local tasks stop appearing as endlessly active after this threshold.
LOCAL_APP_TASK_NO_HEARTBEAT_STALE_MINUTES=10

# Backend: Runs library consistency repair on startup.
# Frontend/Admin: Can restore metadata/local file state before users open the library.
STARTUP_LIBRARY_REPAIR_ENABLED=true

# Backend: Default timeout for local app tasks.
# Frontend/Admin: Applies to long-running buttons such as analysis/stems/SRT when no custom timeout exists.
LOCAL_TASK_DEFAULT_TIMEOUT_SECONDS=1800


# -----------------------------------------------------------------------------
# Security, hosting, backups and exports
# -----------------------------------------------------------------------------

# Backend: Enables stricter enterprise-oriented behavior where implemented.
# Frontend/Admin: Runtime config can show enterprise mode and hide/guard some operations.
ENTERPRISE_MODE=false

# Backend: Allowed Host headers, comma-separated or "*".
# Frontend/Admin: Wrong value can make the app unreachable behind a domain/proxy.
TRUSTED_HOSTS=*

# Backend: Allowed CORS origins, comma-separated. Empty means same-origin/default behavior.
# Frontend/Admin: Needed when frontend and API are served from different origins.
CORS_ALLOW_ORIGINS=

# Backend: Enables security headers middleware.
# Frontend/Admin: Improves browser security; misconfigured headers can affect embedding.
SECURITY_HEADERS_ENABLED=true

# Backend: X-Frame-Options header value.
# Frontend/Admin: Controls whether the app can be embedded in iframes.
SECURITY_FRAME_OPTIONS=DENY

# Backend: Referrer-Policy header.
# Frontend/Admin: Controls how much URL/referrer data the browser sends to external links.
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin

# Backend: Permissions-Policy header.
# Frontend/Admin: Restricts browser APIs such as camera, microphone and geolocation.
SECURITY_PERMISSIONS_POLICY=camera=(), microphone=(), geolocation=()

# Backend: Optional Content-Security-Policy header. Empty disables custom CSP.
# Frontend/Admin: A strict CSP can block scripts/media if not tuned for the deployed frontend.
SECURITY_CSP=

# Backend: Number of days audit logs are retained.
# Frontend/Admin: Affects how far back admin/audit views can inspect activity.
AUDIT_LOG_RETENTION_DAYS=365

# Backend: Directory for backup archives.
# Frontend/Admin: System/backup pages create and list backups from this path.
BACKUP_STORAGE_DIR=storage/backups

# Backend: Default export setting for including soft-deleted records.
# Frontend/Admin: Export dialogs/defaults include deleted data when true.
EXPORT_INCLUDE_DELETED_DEFAULT=false

# Backend: Maximum accepted request body size in MB.
# Frontend/Admin: Controls upload limits for audio, covers, backups and large forms.
MAX_REQUEST_BODY_MB=100


# -----------------------------------------------------------------------------
# Frontend notifications
# -----------------------------------------------------------------------------

# Backend: Publishes runtime setting for auto-closing notification badges.
# Frontend/Admin: Toast/status badges close automatically when enabled.
FRONTEND_BADGE_AUTO_CLOSE_ENABLED=true

# Backend: Auto-close delay in seconds for notification badges.
# Frontend/Admin: Controls how long badges/toasts remain visible.
FRONTEND_BADGE_AUTO_CLOSE_SECONDS=8

# Backend: Publishes whether auto-closed badges should be marked done.
# Frontend/Admin: If true, notifications can disappear from active lists after auto-close.
FRONTEND_BADGE_AUTO_MARK_DONE=false


# -----------------------------------------------------------------------------
# Authentication and users
# -----------------------------------------------------------------------------

# Backend: Allows public user registration when true.
# Frontend/Admin: Shows/enables registration flow instead of admin-only user creation.
ALLOW_REGISTRATION=false

# Backend: Secret used to sign login JWTs. Must be long and private.
# Frontend/Admin: Changing it logs out existing sessions.
JWT_SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET

# Backend: JWT signing algorithm.
# Frontend/Admin: Usually not visible; changing it can invalidate logins.
JWT_ALGORITHM=HS256

# Backend: Login session lifetime in minutes.
# Frontend/Admin: Controls how long users stay logged in before re-authentication.
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Backend: Name of the authentication cookie.
# Frontend/Admin: Changing it logs users out and must match browser cookie behavior.
AUTH_COOKIE_NAME=access_token

# Backend: Marks auth cookie as HTTPS-only when true.
# Frontend/Admin: Set false for plain localhost HTTP; true for production HTTPS.
AUTH_COOKIE_SECURE=true

# Backend: SameSite policy for auth cookie: lax, strict or none.
# Frontend/Admin: Affects login persistence across domains/proxies.
AUTH_COOKIE_SAMESITE=lax

# Backend: Max login attempts per rate-limit window.
# Frontend/Admin: Too many failed logins show rate-limit errors.
AUTH_RATE_LIMIT_LOGIN_REQUESTS=10

# Backend: Max registration attempts per rate-limit window.
# Frontend/Admin: Registration form shows rate-limit errors when exceeded.
AUTH_RATE_LIMIT_REGISTER_REQUESTS=5

# Backend: Rate-limit window in seconds for login/registration.
# Frontend/Admin: Determines how long users must wait after too many attempts.
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Backend: Optional first admin email for non-interactive fresh database setup.
# Frontend/Admin: Creates the initial admin account automatically when DB is empty.
INITIAL_ADMIN_EMAIL=

# Backend: Optional first admin password for non-interactive fresh database setup.
# Frontend/Admin: Allows first login without terminal prompts; keep private.
INITIAL_ADMIN_PASSWORD=

# Backend: Optional display nickname for the first admin user.
# Frontend/Admin: Shown in profile/user areas after initial account creation.
INITIAL_ADMIN_NICKNAME=


# -----------------------------------------------------------------------------
# AI chat, lyrics assistant and global assistant providers
# -----------------------------------------------------------------------------

# Backend: OpenAI API key for chat/lyrics/style/cleanup/report features.
# Frontend/Admin: Marks OpenAI as configured and enables OpenAI models in AI controls.
OPENAI_API_KEY=CHANGE_ME_OR_LEAVE_EMPTY

# Backend: OpenAI-compatible base URL.
# Frontend/Admin: Advanced deployments can point OpenAI provider controls to compatible APIs.
OPENAI_BASE_URL=https://api.openai.com/v1

# Backend: OpenRouter API key for AI text/model routing.
# Frontend/Admin: Marks OpenRouter as configured in admin/runtime AI provider status.
OPENROUTER_API_KEY=CHANGE_ME_OR_LEAVE_EMPTY

# Backend: OpenRouter base URL.
# Frontend/Admin: Affects OpenRouter assistant/style calls.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Backend: Site URL sent to OpenRouter for attribution.
# Frontend/Admin: Not shown directly; useful for provider dashboards.
OPENROUTER_SITE_URL=https://songstudio-react.example.tld

# Backend: App name sent to OpenRouter for attribution.
# Frontend/Admin: Not shown directly; useful for provider dashboards.
OPENROUTER_APP_NAME=Suno FastAPI App

# Backend: Gemini API key for AI text/model routing.
# Frontend/Admin: Marks Gemini as configured and enables Gemini models in AI controls.
GEMINI_API_KEY=CHANGE_ME_OR_LEAVE_EMPTY

# Backend: Gemini base URL.
# Frontend/Admin: Affects Gemini assistant/style calls.
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Backend: Default AI provider used when admin/user has not chosen another provider.
# Frontend/Admin: Preselects provider in AI assistant/style/audio-report controls.
AI_DEFAULT_PROVIDER=openai

# Backend: Default model label for the selected default provider.
# Frontend/Admin: Preselects model in AI assistant/style/audio-report controls.
AI_DEFAULT_MODEL=GPT-5.4-mini

# Backend: Timeout for AI text requests.
# Frontend/Admin: AI actions fail with a visible error after this time.
AI_REQUEST_TIMEOUT_SECONDS=120

# Backend: Default maximum output tokens for AI text calls.
# Frontend/Admin: Affects length/detail of generated lyrics, styles, summaries and reports.
AI_MAX_OUTPUT_TOKENS=6000

# Backend: Stores raw provider responses when true.
# Frontend/Admin: Useful for debugging in admin/status details; increases stored sensitive data risk.
AI_STORE_RAW_RESPONSES=false

# Backend: Max lyrics characters sent to AI style generation.
# Frontend/Admin: Style generator trims/validates long lyrics based on this.
AI_STYLE_LYRICS_MAX_CHARS=5000

# Backend: Max music-style reference characters sent to AI style generation.
# Frontend/Admin: Style generator trims/validates long style references based on this.
AI_STYLE_MUSIC_STYLE_MAX_CHARS=1000

# Backend: Style generation batching mode: auto, batch, chunked or single.
# Frontend/Admin: Affects speed/reliability of /music style suggestion generation.
AI_STYLE_GENERATION_BATCH_MODE=auto

# Backend: Default number of style variants requested per AI batch.
# Frontend/Admin: Controls how many style cards/results are produced per run.
AI_STYLE_GENERATION_DEFAULT_BATCH_SIZE=3

# Backend: Smaller batch size for low-token models.
# Frontend/Admin: Prevents weak/small models from failing on style generation.
AI_STYLE_GENERATION_LOW_TOKEN_BATCH_SIZE=1

# Backend: Output-token limit used for low-token models.
# Frontend/Admin: Keeps style generation usable when a compact model is selected.
AI_STYLE_GENERATION_LOW_TOKEN_MAX_OUTPUT_TOKENS=4000

# Backend: Comma-separated model labels treated as low-token/compact.
# Frontend/Admin: Style generator switches to safer prompts/batches for these models.
AI_STYLE_GENERATION_LOW_TOKEN_MODELS=GPT-5.4-nano,Llama 3.1 8B Instant,GPT-OSS 20B

# Backend: Sends compact references for low-token style models.
# Frontend/Admin: Improves chance of useful style results on small models.
AI_STYLE_GENERATION_COMPACT_REFERENCE_FOR_LOW_TOKEN=true

# Backend: Defers lyric tag assignment during style generation when true.
# Frontend/Admin: Makes style generation more stable and can apply tags in a later step.
AI_STYLE_GENERATION_DEFERRED_LYRIC_TAGGING_ENABLED=true

# Backend: JSON list of model labels allowed per AI provider.
# Frontend/Admin: Controls which models appear in AI provider/model dropdowns.
AI_ALLOWED_MODELS_JSON={"openai":["GPT-5.5","GPT-5.4-mini","GPT-5.4-nano"],"openrouter":["claude-4.6"],"gemini":["gemini-2.5-pro","gemini-flash-latest"],"groq":["Llama 3.3 70B Versatile","Llama 3.1 8B Instant","GPT-OSS 120B","GPT-OSS 20B"]}

# Backend: JSON map from frontend model labels to provider API model IDs.
# Frontend/Admin: Lets the UI show friendly names while backend sends exact provider model IDs.
AI_MODEL_ALIASES_JSON={"openai":{"GPT-5.5":"gpt-5.5","GPT-5.4-mini":"gpt-5.4-mini","GPT-5.4-nano":"gpt-5.4-nano"},"openrouter":{"claude-4.6":"anthropic/claude-sonnet-4.6"},"gemini":{"gemini-2.5-pro":"gemini-2.5-pro","gemini-flash-latest":"gemini-2.5-flash"},"groq":{"Llama 3.3 70B Versatile":"llama-3.3-70b-versatile","Llama 3.1 8B Instant":"llama-3.1-8b-instant","GPT-OSS 120B":"openai/gpt-oss-120b","GPT-OSS 20B":"openai/gpt-oss-20b"}}
